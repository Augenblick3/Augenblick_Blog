---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('fitness', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { date, summary, totalMinutes, mood } = entry.data;

const moodIcon: Record<string, string> = {
  great: '🔥', good: '✓', okay: '○', tired: '…',
};
const moodLabel: Record<string, string> = {
  great: '状态极佳', good: '不错', okay: '一般', tired: '疲惫',
};

const formattedDate = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric', month: 'long', day: 'numeric', weekday: 'long',
}).format(date);
---

<BaseLayout title={formattedDate}>
  <article class="max-w-2xl mx-auto px-6 py-12">
    <header class="mb-8">
      <a href="/fitness" class="text-sm text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors">
        ← 健身记录
      </a>
      <div class="mt-4 flex items-start justify-between">
        <div>
          <time class="font-serif text-2xl font-medium text-gray-900 dark:text-gray-100" datetime={date.toISOString()}>
            {formattedDate}
          </time>
          {summary && (
            <p class="mt-2 text-gray-500 dark:text-gray-400">{summary}</p>
          )}
        </div>
        {mood && (
          <div class="text-right">
            <span class="text-2xl">{moodIcon[mood]}</span>
            <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">{moodLabel[mood]}</p>
          </div>
        )}
      </div>
      {totalMinutes && (
        <p class="mt-2 text-sm text-gray-400 dark:text-gray-500">共 {totalMinutes} 分钟</p>
      )}
      <div class="mt-6 border-t border-gray-100 dark:border-[#1f1f1f]"></div>
    </header>

    <div class="prose prose-gray dark:prose-invert max-w-none
                prose-headings:font-sans prose-headings:font-medium prose-headings:text-base
                prose-ul:my-2 prose-li:my-0.5">
      <Content />
    </div>

    <footer class="mt-12 pt-6 section-divider">
      <a href="/fitness"
         class="text-sm text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors">
        ← 返回健身记录
      </a>
    </footer>
  </article>
</BaseLayout>
