---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allLogs = (await getCollection('fitness', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const currentYear = new Date().getFullYear();

const moodIcon: Record<string, string> = {
  great: '🔥', good: '✓', okay: '○', tired: '…',
};
const moodLabel: Record<string, string> = {
  great: '状态极佳', good: '不错', okay: '一般', tired: '疲惫',
};

// 只有非休息日才算训练天数
const thisWeekStart = new Date();
thisWeekStart.setDate(thisWeekStart.getDate() - thisWeekStart.getDay());
const thisWeekTraining = allLogs.filter(l => l.data.date >= thisWeekStart && !l.data.isRestDay);
const totalMinutesThisWeek = thisWeekTraining.reduce((s, l) => s + (l.data.totalMinutes ?? 0), 0);
const totalTrainingThisYear = allLogs.filter(
  l => l.data.date.getFullYear() === currentYear && !l.data.isRestDay
).length;

function groupByWeek(logs: typeof allLogs) {
  const groups: Record<string, typeof allLogs> = {};
  for (const log of logs) {
    const d = log.data.date;
    const monday = new Date(d);
    monday.setDate(d.getDate() - ((d.getDay() + 6) % 7));
    const key = monday.toISOString().slice(0, 10);
    if (!groups[key]) groups[key] = [];
    groups[key].push(log);
  }
  return groups;
}

const byWeek = groupByWeek(allLogs);

function weekLabel(isoMonday: string) {
  const d = new Date(isoMonday);
  const end = new Date(d);
  end.setDate(d.getDate() + 6);
  const fmt = (date: Date) => new Intl.DateTimeFormat('zh-CN', { month: 'short', day: 'numeric' }).format(date);
  return `${fmt(d)} — ${fmt(end)}`;
}
---

<BaseLayout title="健身">
  <div class="max-w-3xl mx-auto px-6 py-12">
    <header class="mb-10">
      <p class="text-xs tracking-[0.3em] uppercase text-[#9a9189] dark:text-[#6a6560] mb-3">Fitness</p>
      <h1 class="font-serif text-4xl font-medium text-[#302d29] dark:text-[#c8c2b8]">健身</h1>
      <p class="mt-3 text-[#9a9189] dark:text-[#6a6560]">每日运动记录</p>

      <!-- Quick stats (仅统计训练日) -->
      <div class="grid grid-cols-3 gap-4 mt-6">
        <div class="p-4 rounded-xl bg-[#faf8f4] dark:bg-[#222019]
                    border border-[#dbd8d3] dark:border-[#2c2925] text-center">
          <p class="text-2xl font-light text-[#302d29] dark:text-[#c8c2b8]">{totalTrainingThisYear}</p>
          <p class="text-xs text-[#9a9189] dark:text-[#6a6560] mt-1">{currentYear} 年训练天数</p>
        </div>
        <div class="p-4 rounded-xl bg-[#faf8f4] dark:bg-[#222019]
                    border border-[#dbd8d3] dark:border-[#2c2925] text-center">
          <p class="text-2xl font-light text-[#302d29] dark:text-[#c8c2b8]">{thisWeekTraining.length}</p>
          <p class="text-xs text-[#9a9189] dark:text-[#6a6560] mt-1">本周训练天数</p>
        </div>
        <div class="p-4 rounded-xl bg-[#faf8f4] dark:bg-[#222019]
                    border border-[#dbd8d3] dark:border-[#2c2925] text-center">
          <p class="text-2xl font-light text-[#302d29] dark:text-[#c8c2b8]">{totalMinutesThisWeek}</p>
          <p class="text-xs text-[#9a9189] dark:text-[#6a6560] mt-1">本周分钟数</p>
        </div>
      </div>
    </header>

    {Object.keys(byWeek).length === 0 ? (
      <div class="text-center py-20 text-[#9a9189] dark:text-[#6a6560]">
        <p class="font-serif italic text-lg">尚无记录</p>
        <p class="text-sm mt-2">前往 /admin 开始记录</p>
      </div>
    ) : (
      <div class="space-y-8">
        {Object.entries(byWeek).map(([monday, logs]) => (
          <div>
            <h2 class="text-xs font-medium tracking-wide text-[#9a9189] dark:text-[#6a6560] mb-3 uppercase">
              {weekLabel(monday)}
            </h2>
            <div class="space-y-2">
              {logs.map((log) => (
                log.data.isRestDay ? (
                  /* 休息日：灰淡显示，不可点击进入详情（或可进入写备注） */
                  <a href={`/fitness/${log.slug}`}
                     class="flex items-center gap-4 p-4 rounded-xl opacity-50
                            border border-dashed border-[#dbd8d3] dark:border-[#2c2925]
                            hover:opacity-70 transition-opacity">
                    <div class="text-center w-10 shrink-0">
                      <p class="text-xs text-[#9a9189] dark:text-[#6a6560]">
                        {new Intl.DateTimeFormat('zh-CN', { weekday: 'short' }).format(log.data.date)}
                      </p>
                      <p class="text-lg font-light text-[#9a9189] dark:text-[#6a6560]">
                        {log.data.date.getDate()}
                      </p>
                    </div>
                    <div class="flex-1">
                      <p class="text-sm text-[#9a9189] dark:text-[#6a6560]">
                        {log.data.summary ?? '休息'}
                      </p>
                    </div>
                    <span class="text-xs text-[#9a9189] dark:text-[#6a6560] shrink-0">休息日</span>
                  </a>
                ) : (
                  /* 训练日 */
                  <a href={`/fitness/${log.slug}`}
                     class="group flex items-center gap-4 p-4 rounded-xl
                            border border-[#e8e4de] dark:border-[#2c2925]
                            hover:border-[#dbd8d3] dark:hover:border-[#3d3a35]
                            hover:bg-[#faf8f4] dark:hover:bg-[#222019]
                            transition-all duration-150">
                    <div class="text-center w-10 shrink-0">
                      <p class="text-xs text-[#9a9189] dark:text-[#6a6560]">
                        {new Intl.DateTimeFormat('zh-CN', { weekday: 'short' }).format(log.data.date)}
                      </p>
                      <p class="text-lg font-light text-[#302d29] dark:text-[#c8c2b8]">
                        {log.data.date.getDate()}
                      </p>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm text-[#4a4540] dark:text-[#a8a29a] truncate
                                group-hover:text-[#302d29] dark:group-hover:text-[#c8c2b8] transition-colors">
                        {log.data.summary ?? '点击查看详情'}
                      </p>
                      {log.data.totalMinutes && (
                        <p class="text-xs text-[#9a9189] dark:text-[#6a6560] mt-0.5">
                          {log.data.totalMinutes} 分钟
                        </p>
                      )}
                    </div>
                    {log.data.mood && (
                      <span class="text-sm text-[#9a9189] dark:text-[#6a6560] shrink-0"
                            title={moodLabel[log.data.mood]}>
                        {moodIcon[log.data.mood]}
                      </span>
                    )}
                  </a>
                )
              ))}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
