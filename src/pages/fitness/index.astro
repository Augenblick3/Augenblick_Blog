---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allLogs = (await getCollection('fitness', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const currentYear = new Date().getFullYear();

const moodIcon: Record<string, string> = {
  great: '🔥',
  good:  '✓',
  okay:  '○',
  tired: '…',
};
const moodLabel: Record<string, string> = {
  great: '状态极佳',
  good:  '不错',
  okay:  '一般',
  tired: '疲惫',
};

// Calculate weekly stats
const thisWeekStart = new Date();
thisWeekStart.setDate(thisWeekStart.getDate() - thisWeekStart.getDay());
const thisWeekLogs = allLogs.filter(l => l.data.date >= thisWeekStart);
const totalMinutesThisWeek = thisWeekLogs.reduce((s, l) => s + (l.data.totalMinutes ?? 0), 0);
const totalLogsThisYear = allLogs.filter(l => l.data.date.getFullYear() === currentYear).length;

// Group by week
function groupByWeek(logs: typeof allLogs) {
  const groups: Record<string, typeof allLogs> = {};
  for (const log of logs) {
    const d = log.data.date;
    const monday = new Date(d);
    monday.setDate(d.getDate() - ((d.getDay() + 6) % 7));
    const key = monday.toISOString().slice(0, 10);
    if (!groups[key]) groups[key] = [];
    groups[key].push(log);
  }
  return groups;
}

const byWeek = groupByWeek(allLogs);

function weekLabel(isoMonday: string) {
  const d = new Date(isoMonday);
  const end = new Date(d);
  end.setDate(d.getDate() + 6);
  const fmt = (date: Date) => new Intl.DateTimeFormat('zh-CN', { month: 'short', day: 'numeric' }).format(date);
  return `${fmt(d)} — ${fmt(end)}`;
}
---

<BaseLayout title="健身">
  <div class="max-w-3xl mx-auto px-6 py-12">
    <header class="mb-10">
      <p class="text-xs tracking-[0.3em] uppercase text-gray-400 dark:text-gray-500 mb-3">Fitness</p>
      <h1 class="font-serif text-4xl font-medium text-gray-900 dark:text-gray-100">健身</h1>
      <p class="mt-3 text-gray-500 dark:text-gray-400">每日运动记录</p>

      <!-- Quick stats -->
      <div class="grid grid-cols-3 gap-4 mt-6">
        <div class="p-4 rounded-xl bg-white dark:bg-[#141414] border border-gray-200 dark:border-[#262626] text-center">
          <p class="text-2xl font-light text-gray-900 dark:text-gray-100">{totalLogsThisYear}</p>
          <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">{currentYear} 年训练天数</p>
        </div>
        <div class="p-4 rounded-xl bg-white dark:bg-[#141414] border border-gray-200 dark:border-[#262626] text-center">
          <p class="text-2xl font-light text-gray-900 dark:text-gray-100">{thisWeekLogs.length}</p>
          <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">本周训练天数</p>
        </div>
        <div class="p-4 rounded-xl bg-white dark:bg-[#141414] border border-gray-200 dark:border-[#262626] text-center">
          <p class="text-2xl font-light text-gray-900 dark:text-gray-100">{totalMinutesThisWeek}</p>
          <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">本周分钟数</p>
        </div>
      </div>
    </header>

    <!-- Weekly groups -->
    {Object.keys(byWeek).length === 0 ? (
      <div class="text-center py-20 text-gray-400 dark:text-gray-600">
        <p class="font-serif italic text-lg">尚无记录</p>
        <p class="text-sm mt-2">前往 /admin 开始记录</p>
      </div>
    ) : (
      <div class="space-y-8">
        {Object.entries(byWeek).map(([monday, logs]) => (
          <div>
            <h2 class="text-xs font-medium tracking-wide text-gray-400 dark:text-gray-500 mb-3 uppercase">
              {weekLabel(monday)}
            </h2>
            <div class="space-y-2">
              {logs.map((log) => (
                <a href={`/fitness/${log.slug}`}
                   class="group flex items-center gap-4 p-4 rounded-xl
                          border border-gray-100 dark:border-[#1f1f1f]
                          hover:border-gray-200 dark:hover:border-[#262626]
                          hover:bg-white dark:hover:bg-[#141414]
                          transition-all duration-150">

                  <!-- Date -->
                  <div class="text-center w-10 flex-shrink-0">
                    <p class="text-xs text-gray-400 dark:text-gray-500">
                      {new Intl.DateTimeFormat('zh-CN', { weekday: 'short' }).format(log.data.date)}
                    </p>
                    <p class="text-lg font-light text-gray-900 dark:text-gray-100">
                      {log.data.date.getDate()}
                    </p>
                  </div>

                  <!-- Summary -->
                  <div class="flex-1 min-w-0">
                    <p class="text-sm text-gray-700 dark:text-gray-300 truncate">
                      {log.data.summary ?? '点击查看详情'}
                    </p>
                    {log.data.totalMinutes && (
                      <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">
                        {log.data.totalMinutes} 分钟
                      </p>
                    )}
                  </div>

                  <!-- Mood -->
                  {log.data.mood && (
                    <span class="text-sm text-gray-400 dark:text-gray-500 flex-shrink-0"
                          title={moodLabel[log.data.mood]}>
                      {moodIcon[log.data.mood]}
                    </span>
                  )}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
