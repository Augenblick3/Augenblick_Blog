---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatMediaDateLabel, getMediaEndDate, getMediaStartDate } from '../../utils/mediaDates';

export async function getStaticPaths() {
  const entries = await getCollection('media', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const {
  title, type, creator, yearCreated, dateConsumed, dateConsumedEnd, rating, cover, tags,
  // Film/TV
  screenwriter, leadActor, leadActress, cast,
  // Book
  translator,
  // Music
  lyricist, composer, arranger,
} = entry.data;

const typeLabel: Record<string, string> = {
  film: '电影', tv: '剧集', music: '音乐', album: '专辑', book: '书',
};

// Role label for the main "creator" field, by type
const creatorRole: Record<string, string> = {
  film: '导演', tv: '导演', music: '演唱', album: '演唱', book: '作者',
};

const mediaDate = { dateConsumed, dateConsumedEnd };
const startDate = getMediaStartDate(mediaDate);
const endDate = getMediaEndDate(mediaDate);
const formattedStartDate = formatMediaDateLabel({ dateConsumed: startDate });
const formattedEndDate = formatMediaDateLabel({ dateConsumed: endDate });
const formattedDate = formatMediaDateLabel(mediaDate);
const isRange = Boolean(dateConsumedEnd && startDate.getTime() !== endDate.getTime());

const stars = rating ? { filled: rating, empty: 5 - rating } : null;
const isScreen = type === 'film' || type === 'tv';
const isBook = type === 'book';
const isMusic = type === 'music' || type === 'album';

// Build credits rows: [label, value] — only include filled fields
type CreditRow = [string, string];
const credits: CreditRow[] = [];

if (creator)                   credits.push([creatorRole[type] ?? '创作者', creator]);
if (isScreen && screenwriter)  credits.push(['编剧', screenwriter]);
if (isScreen && leadActor)     credits.push(['男主', leadActor]);
if (isScreen && leadActress)   credits.push(['女主', leadActress]);
if (isScreen && cast?.length)  credits.push(['其他演员', cast.join(' · ')]);
if (isBook && translator)      credits.push(['译者', translator]);
if (isMusic && lyricist)       credits.push(['作词', lyricist]);
if (isMusic && composer)       credits.push(['作曲', composer]);
if (isMusic && arranger)       credits.push(['编曲', arranger]);
if (yearCreated)               credits.push(['年份', String(yearCreated)]);
---

<BaseLayout title={title}>
  <article class="max-w-2xl mx-auto px-6 py-12">

    <!-- Cover + header -->
    <header class="mb-10">
      {cover && (
        <div class="mb-8 -mx-6 sm:mx-0" style="clear:both">
          <img src={cover} alt={title}
               class="w-full sm:w-44 sm:float-right sm:ml-8 sm:rounded-xl
                      sm:shadow-md object-cover aspect-[2/3] sm:aspect-auto sm:h-64" />
        </div>
      )}

      <!-- Type badge + tags -->
      <div class="flex items-center gap-2 mb-3 flex-wrap">
        <span class="text-xs px-2 py-0.5 rounded
                     bg-[#edeae4] dark:bg-[#2c2925]
                     text-[#7a7670] dark:text-[#7a7670] font-medium">
          {typeLabel[type]}
        </span>
        {tags?.map((tag) => <span class="tag-pill">{tag}</span>)}
      </div>

      <!-- Title -->
      <h1 class="font-serif text-3xl font-medium text-[#302d29] dark:text-[#c8c2b8] leading-snug mb-4">
        {title}
      </h1>

      <!-- Credits table -->
      {credits.length > 0 && (
        <dl class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-1.5 mb-4 text-sm">
          {credits.map(([label, value]) => (
            <>
              <dt class="text-[#9a9189] dark:text-[#6a6560] whitespace-nowrap">{label}</dt>
              <dd class="text-[#4a4540] dark:text-[#a8a29a]">{value}</dd>
            </>
          ))}
        </dl>
      )}

      <!-- Stars + date -->
      <div class="flex items-center gap-4 mt-4">
        {stars && (
          <span class="text-base tracking-tight" aria-label={`${rating} 星`}>
            <span class="text-amber-400">{'★'.repeat(stars.filled)}</span>
            <span class="text-[#dbd8d3] dark:text-[#3d3a35]">{'★'.repeat(stars.empty)}</span>
          </span>
        )}
        {isRange ? (
          <span class="text-sm text-[#9a9189] dark:text-[#6a6560]">
            <time datetime={startDate.toISOString()}>{formattedStartDate}</time>
            {' — '}
            <time datetime={endDate.toISOString()}>{formattedEndDate}</time>
          </span>
        ) : (
          <time class="text-sm text-[#9a9189] dark:text-[#6a6560]" datetime={startDate.toISOString()}>
            {formattedDate}
          </time>
        )}
      </div>

      <div class="mt-6 border-t border-[#e8e4de] dark:border-[#2c2925]" style="clear:both"></div>
    </header>

    <!-- Body content -->
    <div class="prose prose-gray dark:prose-invert max-w-none
                prose-headings:font-serif prose-headings:font-medium
                prose-a:text-indigo-600 dark:prose-a:text-indigo-400
                prose-blockquote:not-italic prose-blockquote:font-serif
                prose-code:text-sm">
      <Content />
    </div>

    <footer class="mt-16 pt-8 border-t border-[#e8e4de] dark:border-[#2c2925]">
      <a href="/media"
         class="text-sm text-[#9a9189] dark:text-[#6a6560]
                hover:text-[#302d29] dark:hover:text-[#c8c2b8] transition-colors">
        ← 返回媒介
      </a>
    </footer>
  </article>
</BaseLayout>
