---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const recentFitness = (await getCollection('fitness', ({ data }) => !data.draft && !data.isRestDay))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

const recentResearch = (await getCollection('research', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const recentMusings = (await getCollection('musings', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const allMedia = (await getCollection('media', ({ data }) => !data.draft))
  .sort((a, b) => b.data.dateConsumed.getTime() - a.data.dateConsumed.getTime())
  .slice(0, 4);

const typeLabel: Record<string, string> = {
  film: '电影', tv: '剧集', music: '音乐', album: '专辑', book: '书',
};
const researchTypeLabel: Record<string, string> = {
  'project': '项目', 'paper-note': '读文', 'technical': '技术', 'weekly': '周报',
};

const latestUpdatedAt = [
  allMedia[0]?.data.dateConsumed,
  recentResearch[0]?.data.date,
  recentMusings[0]?.data.date,
  recentFitness[0]?.data.date,
]
  .filter((date): date is Date => Boolean(date))
  .sort((a, b) => b.getTime() - a.getTime())[0];

const formattedLatestUpdatedAt = latestUpdatedAt
  ? new Intl.DateTimeFormat('zh-CN', {
      year: 'numeric',
      month: '2-digit',
      day: '2-digit',
    }).format(latestUpdatedAt).replaceAll('/', '.')
  : null;
---

<BaseLayout>
  <section class="min-h-[calc(100vh-4rem)] flex flex-col justify-center px-6 py-16">
    <div class="max-w-5xl mx-auto w-full">

      <div class="mb-8 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <p class="font-serif text-lg font-medium text-[#302d29] dark:text-[#c8c2b8]">
          一些正在发生的记录
        </p>
        {formattedLatestUpdatedAt && (
          <p class="text-[11px] tracking-[0.18em] text-[#9a9189] dark:text-[#6a6560] uppercase">
            最近更新 · {formattedLatestUpdatedAt}
          </p>
        )}
      </div>

      <!-- 4 Module Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">

        <!-- Media Card -->
        <a href="/media"
           class="group relative flex flex-col p-7 rounded-2xl
                  border border-[#dbd8d3] dark:border-[#2c2925]
                  bg-[#faf8f4] dark:bg-[#222019]
                  hover:border-[#c8c4be] dark:hover:border-[#3d3a35]
                  hover:shadow-sm transition-all duration-200">
          <span class="text-xl mb-5 opacity-60">◎</span>
          <h2 class="font-serif text-lg font-medium text-[#302d29] dark:text-[#c8c2b8] mb-1.5">
            媒介
          </h2>
          <p class="text-xs text-[#9a9189] dark:text-[#6a6560] leading-relaxed mb-5">
            影视 · 音乐 · 文学
          </p>
          {allMedia.length > 0 && (
            <ul class="space-y-2 border-t border-[#e8e4de] dark:border-[#2c2925] pt-4 mt-auto">
              {allMedia.map((item) => (
                <li class="flex items-center gap-2 text-xs text-[#9a9189] dark:text-[#6a6560]">
                  <span class="shrink-0 px-1.5 py-0.5 rounded bg-[#edeae4] dark:bg-[#2c2925] text-[#7a7670]">
                    {typeLabel[item.data.type]}
                  </span>
                  <span class="truncate">{item.data.title}</span>
                </li>
              ))}
            </ul>
          )}
          <span class="absolute bottom-5 right-5 text-[#c8c4be] dark:text-[#3d3a35]
                       group-hover:text-[#9a9189] dark:group-hover:text-[#6a6560] transition-colors text-sm">→</span>
        </a>

        <!-- Research Card -->
        <a href="/research"
           class="group relative flex flex-col p-7 rounded-2xl
                  border border-[#dbd8d3] dark:border-[#2c2925]
                  bg-[#faf8f4] dark:bg-[#222019]
                  hover:border-[#c8c4be] dark:hover:border-[#3d3a35]
                  hover:shadow-sm transition-all duration-200">
          <span class="text-xl mb-5 opacity-60">∂</span>
          <h2 class="font-serif text-lg font-medium text-[#302d29] dark:text-[#c8c2b8] mb-1.5">
            科研
          </h2>
          <p class="text-xs text-[#9a9189] dark:text-[#6a6560] leading-relaxed mb-5">
            项目进展 · 读文笔记
          </p>
          {recentResearch.length > 0 && (
            <ul class="space-y-2 border-t border-[#e8e4de] dark:border-[#2c2925] pt-4 mt-auto">
              {recentResearch.map((post) => (
                <li class="flex items-center gap-2 text-xs text-[#9a9189] dark:text-[#6a6560]">
                  <span class="shrink-0 px-1.5 py-0.5 rounded bg-[#edeae4] dark:bg-[#2c2925] text-[#7a7670]">
                    {researchTypeLabel[post.data.type]}
                  </span>
                  <span class="truncate">{post.data.title}</span>
                </li>
              ))}
            </ul>
          )}
          <span class="absolute bottom-5 right-5 text-[#c8c4be] dark:text-[#3d3a35]
                       group-hover:text-[#9a9189] dark:group-hover:text-[#6a6560] transition-colors text-sm">→</span>
        </a>

        <!-- Musings Card -->
        <a href="/musings"
           class="group relative flex flex-col p-7 rounded-2xl
                  border border-[#dbd8d3] dark:border-[#2c2925]
                  bg-[#faf8f4] dark:bg-[#222019]
                  hover:border-[#c8c4be] dark:hover:border-[#3d3a35]
                  hover:shadow-sm transition-all duration-200">
          <span class="text-xl mb-5 opacity-60">～</span>
          <h2 class="font-serif text-lg font-medium text-[#302d29] dark:text-[#c8c2b8] mb-1.5">
            随想
          </h2>
          <p class="text-xs text-[#9a9189] dark:text-[#6a6560] leading-relaxed mb-5">
            零散的想法与文字
          </p>
          {recentMusings.length > 0 && (
            <ul class="space-y-2 border-t border-[#e8e4de] dark:border-[#2c2925] pt-4 mt-auto">
              {recentMusings.map((post) => (
                <li class="text-xs text-[#9a9189] dark:text-[#6a6560] truncate">
                  {post.data.title}
                </li>
              ))}
            </ul>
          )}
          <span class="absolute bottom-5 right-5 text-[#c8c4be] dark:text-[#3d3a35]
                       group-hover:text-[#9a9189] dark:group-hover:text-[#6a6560] transition-colors text-sm">→</span>
        </a>

        <!-- Fitness Card -->
        <a href="/fitness"
           class="group relative flex flex-col p-7 rounded-2xl
                  border border-[#dbd8d3] dark:border-[#2c2925]
                  bg-[#faf8f4] dark:bg-[#222019]
                  hover:border-[#c8c4be] dark:hover:border-[#3d3a35]
                  hover:shadow-sm transition-all duration-200">
          <span class="text-xl mb-5 opacity-60">◈</span>
          <h2 class="font-serif text-lg font-medium text-[#302d29] dark:text-[#c8c2b8] mb-1.5">
            健身
          </h2>
          <p class="text-xs text-[#9a9189] dark:text-[#6a6560] leading-relaxed mb-5">
            每日运动记录
          </p>
          {recentFitness.length > 0 && (
            <ul class="space-y-2 border-t border-[#e8e4de] dark:border-[#2c2925] pt-4 mt-auto">
              {recentFitness.map((log) => (
                <li class="flex items-center gap-2 text-xs text-[#9a9189] dark:text-[#6a6560]">
                  <span class="tabular-nums shrink-0">
                    {new Intl.DateTimeFormat('zh-CN', { month: '2-digit', day: '2-digit' })
                      .format(log.data.date)}
                  </span>
                  <span class="truncate">{log.data.summary ?? '训练日志'}</span>
                </li>
              ))}
            </ul>
          )}
          <span class="absolute bottom-5 right-5 text-[#c8c4be] dark:text-[#3d3a35]
                       group-hover:text-[#9a9189] dark:group-hover:text-[#6a6560] transition-colors text-sm">→</span>
        </a>

      </div>
    </div>
  </section>
</BaseLayout>
