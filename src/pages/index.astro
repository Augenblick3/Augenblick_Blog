---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const recentFitness = (await getCollection('fitness', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

const recentResearch = (await getCollection('research', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const recentMusings = (await getCollection('musings', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const allMedia = (await getCollection('media', ({ data }) => !data.draft))
  .sort((a, b) => b.data.dateConsumed.getTime() - a.data.dateConsumed.getTime())
  .slice(0, 4);

const currentYear = new Date().getFullYear();

const typeLabel: Record<string, string> = {
  film: '电影',
  tv: '剧集',
  music: '音乐',
  album: '专辑',
  book: '书',
};

const researchTypeLabel: Record<string, string> = {
  'project': '项目',
  'paper-note': '读文',
  'technical': '技术',
  'weekly': '周报',
};
---

<BaseLayout>
  <!-- Hero Section -->
  <section class="min-h-[calc(100vh-4rem)] flex flex-col items-center justify-center px-6 text-center">
    <p class="text-xs tracking-[0.3em] uppercase text-gray-400 dark:text-gray-500 mb-6">
      {currentYear}
    </p>
    <h1 class="font-serif text-6xl sm:text-7xl font-medium text-gray-900 dark:text-gray-100 mb-4
               tracking-tight leading-none">
      Augenblick
    </h1>
    <p class="font-serif italic text-xl text-gray-400 dark:text-gray-500 mb-2">
      瞬息皆永恒
    </p>
    <p class="text-sm text-gray-400 dark:text-gray-500 max-w-xs mt-2 leading-relaxed">
      影视·音乐·文学 / 科研进展 / 随想
    </p>

    <!-- Scroll indicator -->
    <div class="absolute bottom-12 animate-bounce">
      <svg class="w-5 h-5 text-gray-300 dark:text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </section>

  <!-- Module Cards -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">

      <!-- Media Card -->
      <a href="/media"
         class="group relative p-8 rounded-xl border border-gray-200 dark:border-[#262626]
                bg-white dark:bg-[#141414] card-hover block">
        <div class="mb-6">
          <span class="text-2xl">◎</span>
        </div>
        <h2 class="font-serif text-xl font-medium text-gray-900 dark:text-gray-100 mb-2">
          媒介
        </h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed mb-6">
          影视 · 音乐 · 文学<br/>今年看过、听过、读过的
        </p>
        {allMedia.length > 0 && (
          <ul class="space-y-2 border-t border-gray-100 dark:border-[#1f1f1f] pt-4">
            {allMedia.map((item) => (
              <li class="flex items-center gap-2 text-xs text-gray-400 dark:text-gray-500">
                <span class="tag-pill">{typeLabel[item.data.type]}</span>
                <span class="truncate">{item.data.title}</span>
              </li>
            ))}
          </ul>
        )}
        <div class="absolute bottom-6 right-6 text-gray-300 dark:text-gray-600
                    group-hover:text-gray-500 dark:group-hover:text-gray-400 transition-colors">
          →
        </div>
      </a>

      <!-- Research Card -->
      <a href="/research"
         class="group relative p-8 rounded-xl border border-gray-200 dark:border-[#262626]
                bg-white dark:bg-[#141414] card-hover block">
        <div class="mb-6">
          <span class="text-2xl">∂</span>
        </div>
        <h2 class="font-serif text-xl font-medium text-gray-900 dark:text-gray-100 mb-2">
          科研
        </h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed mb-6">
          项目进展 · 读文笔记<br/>技术探索 · 每周小结
        </p>
        {recentResearch.length > 0 && (
          <ul class="space-y-2 border-t border-gray-100 dark:border-[#1f1f1f] pt-4">
            {recentResearch.map((post) => (
              <li class="flex items-center gap-2 text-xs text-gray-400 dark:text-gray-500">
                <span class="tag-pill">{researchTypeLabel[post.data.type]}</span>
                <span class="truncate">{post.data.title}</span>
              </li>
            ))}
          </ul>
        )}
        <div class="absolute bottom-6 right-6 text-gray-300 dark:text-gray-600
                    group-hover:text-gray-500 dark:group-hover:text-gray-400 transition-colors">
          →
        </div>
      </a>

      <!-- Musings Card -->
      <a href="/musings"
         class="group relative p-8 rounded-xl border border-gray-200 dark:border-[#262626]
                bg-white dark:bg-[#141414] card-hover block">
        <div class="mb-6">
          <span class="text-2xl">～</span>
        </div>
        <h2 class="font-serif text-xl font-medium text-gray-900 dark:text-gray-100 mb-2">
          随想
        </h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed mb-6">
          一些零散的想法<br/>与不成系统的文字
        </p>
        {recentMusings.length > 0 && (
          <ul class="space-y-2 border-t border-gray-100 dark:border-[#1f1f1f] pt-4">
            {recentMusings.map((post) => (
              <li class="text-xs text-gray-400 dark:text-gray-500 truncate">
                {post.data.title}
              </li>
            ))}
          </ul>
        )}
        <div class="absolute bottom-6 right-6 text-gray-300 dark:text-gray-600
                    group-hover:text-gray-500 dark:group-hover:text-gray-400 transition-colors">
          →
        </div>
      </a>

      <!-- Fitness Card -->
      <a href="/fitness"
         class="group relative p-8 rounded-xl border border-gray-200 dark:border-[#262626]
                bg-white dark:bg-[#141414] card-hover block">
        <div class="mb-6">
          <span class="text-2xl">◈</span>
        </div>
        <h2 class="font-serif text-xl font-medium text-gray-900 dark:text-gray-100 mb-2">
          健身
        </h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed mb-6">
          每日运动记录<br/>训练量与状态追踪
        </p>
        {recentFitness.length > 0 && (
          <ul class="space-y-2 border-t border-gray-100 dark:border-[#1f1f1f] pt-4">
            {recentFitness.map((log) => (
              <li class="flex items-center gap-2 text-xs text-gray-400 dark:text-gray-500">
                <span class="tabular-nums">
                  {new Intl.DateTimeFormat('zh-CN', { month: '2-digit', day: '2-digit' })
                    .format(log.data.date)}
                </span>
                <span class="truncate">{log.data.summary ?? '训练日志'}</span>
              </li>
            ))}
          </ul>
        )}
        <div class="absolute bottom-6 right-6 text-gray-300 dark:text-gray-600
                    group-hover:text-gray-500 dark:group-hover:text-gray-400 transition-colors">
          →
        </div>
      </a>

    </div>
  </section>
</BaseLayout>
