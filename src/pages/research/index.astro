---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('research', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const typeLabel: Record<string, string> = {
  'project': 'Project',
  'paper-note': 'Paper',
  'technical': 'Tech',
  'weekly': 'Weekly',
};

const typeColor: Record<string, string> = {
  'project': 'bg-blue-50 dark:bg-blue-950/30 text-blue-600 dark:text-blue-400',
  'paper-note': 'bg-amber-50 dark:bg-amber-950/30 text-amber-600 dark:text-amber-400',
  'technical': 'bg-emerald-50 dark:bg-emerald-950/30 text-emerald-600 dark:text-emerald-400',
  'weekly': 'bg-gray-100 dark:bg-[#1f1f1f] text-gray-500 dark:text-gray-400',
};

// Group by type for the filter display
const grouped = {
  all: allPosts,
  project: allPosts.filter(p => p.data.type === 'project'),
  'paper-note': allPosts.filter(p => p.data.type === 'paper-note'),
  technical: allPosts.filter(p => p.data.type === 'technical'),
  weekly: allPosts.filter(p => p.data.type === 'weekly'),
};
---

<BaseLayout title="科研">
  <div class="max-w-3xl mx-auto px-6 py-12">
    <header class="mb-12">
      <p class="text-xs tracking-[0.3em] uppercase text-gray-400 dark:text-gray-500 mb-3">Research</p>
      <h1 class="font-serif text-4xl font-medium text-gray-900 dark:text-gray-100">科研</h1>
      <p class="mt-3 text-gray-500 dark:text-gray-400">
        项目进展 · 读文笔记 · 技术探索 · 每周小结
      </p>
    </header>

    <!-- Filter tabs -->
    <div class="flex flex-wrap gap-2 mb-8" id="filter-tabs">
      {(['all', 'project', 'paper-note', 'technical', 'weekly'] as const).map((key) => (
        <button
          data-filter={key}
          class={`filter-btn px-3 py-1.5 text-sm rounded-lg transition-all duration-150
                  ${key === 'all'
                    ? 'bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900'
                    : 'bg-gray-100 dark:bg-[#1f1f1f] text-gray-500 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-[#2a2a2a]'
                  }`}>
          {key === 'all' ? `全部 (${allPosts.length})` : `${typeLabel[key]} (${grouped[key].length})`}
        </button>
      ))}
    </div>

    <!-- Posts list -->
    {allPosts.length === 0 ? (
      <div class="text-center py-20 text-gray-400 dark:text-gray-600">
        <p class="font-serif italic text-lg">尚无内容</p>
        <p class="text-sm mt-2">前往 /admin 开始写作</p>
      </div>
    ) : (
      <ul class="space-y-px" id="posts-list">
        {allPosts.map((post) => (
          <li data-type={post.data.type} class="post-item">
            <a href={`/research/${post.slug}`}
               class="group flex items-start gap-4 py-5 border-b border-gray-100 dark:border-[#1a1a1a]
                      hover:bg-transparent transition-colors">
              <time class="text-xs text-gray-400 dark:text-gray-500 pt-1 w-20 flex-shrink-0 tabular-nums">
                {new Intl.DateTimeFormat('zh-CN', { month: '2-digit', day: '2-digit' })
                  .format(post.data.date)}
              </time>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class={`text-xs px-1.5 py-0.5 rounded font-medium ${typeColor[post.data.type]}`}>
                    {typeLabel[post.data.type]}
                  </span>
                  {post.data.tags?.slice(0, 2).map((tag) => (
                    <span class="tag-pill">{tag}</span>
                  ))}
                </div>
                <p class="font-medium text-gray-900 dark:text-gray-100 truncate
                           group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
                  {post.data.title}
                </p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.post-item');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter!;

      // Update active button style
      buttons.forEach((b) => {
        b.classList.remove('bg-gray-900', 'dark:bg-gray-100', 'text-white', 'dark:text-gray-900');
        b.classList.add('bg-gray-100', 'dark:bg-[#1f1f1f]', 'text-gray-500', 'dark:text-gray-400');
      });
      btn.classList.add('bg-gray-900', 'dark:bg-gray-100', 'text-white', 'dark:text-gray-900');
      btn.classList.remove('bg-gray-100', 'dark:bg-[#1f1f1f]', 'text-gray-500', 'dark:text-gray-400');

      // Filter items
      items.forEach((item) => {
        const el = item as HTMLElement;
        if (filter === 'all' || el.dataset.type === filter) {
          el.style.display = '';
        } else {
          el.style.display = 'none';
        }
      });
    });
  });
</script>
