---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  tags?: string[];
  description?: string;
}

const { title, date, tags = [], description } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date);
---

<BaseLayout title={title} description={description}>
  <article class="max-w-2xl mx-auto px-6 py-12">
    <header class="mb-10">
      <div class="mb-4 flex items-center gap-3 text-sm text-gray-400 dark:text-gray-500">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {tags.length > 0 && (
          <>
            <span>·</span>
            <div class="flex gap-1.5 flex-wrap">
              {tags.map((tag) => (
                <span class="tag-pill">{tag}</span>
              ))}
            </div>
          </>
        )}
      </div>
      <h1 class="font-serif text-3xl font-medium leading-snug text-gray-900 dark:text-gray-100">
        {title}
      </h1>
    </header>

    <div class="prose prose-gray dark:prose-invert max-w-none
                prose-base prose-headings:font-serif prose-headings:font-medium
                prose-a:text-indigo-600 dark:prose-a:text-indigo-400
                prose-code:text-sm prose-pre:bg-transparent prose-pre:p-0
                prose-p:leading-[1.9] prose-p:text-[1.0625rem]
                prose-li:leading-[1.9] prose-li:text-[1.0625rem]">
      <slot />
    </div>

    <footer class="mt-16 pt-8 section-divider">
      <a href="javascript:history.back()"
         class="text-sm text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors">
        ← 返回
      </a>
    </footer>
  </article>
</BaseLayout>
