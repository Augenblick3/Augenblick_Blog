---
interface Props {
  source?: string;
}
const { source } = Astro.props;
---

<!--
  Usage in MDX:
  import PullQuote from '@/components/PullQuote.astro';
  <PullQuote source="歌词 / 对白来源">
    这里放你想引用的歌词或台词
  </PullQuote>
-->

<figure class="my-10 relative">
  <!-- Decorative quotation mark -->
  <span class="absolute -top-4 -left-2 text-7xl leading-none select-none
               text-gray-100 dark:text-[#1f1f1f] font-serif pointer-events-none">
    "
  </span>

  <blockquote class="relative z-10 pl-6 border-l-2 border-indigo-300 dark:border-indigo-700
                     font-serif italic text-xl leading-relaxed
                     text-gray-700 dark:text-gray-300">
    <slot />
  </blockquote>

  {source && (
    <figcaption class="mt-3 pl-6 text-sm text-gray-400 dark:text-gray-500 not-italic">
      — {source}
    </figcaption>
  )}
</figure>
